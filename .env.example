# ============ X API (developer.x.com > your app > Keys & Tokens) ============
# App permissions must be "Read and Write". See docs/SETUP_X_API.md
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ============ OBS (Tools > WebSocket Server Settings) ============
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=
# Must match OBS Settings > Output > Recording path:
OBS_REPLAY_DIR=C:\Users\YOU\Videos

# ============ Voice commands ============
# "aye clip that"  -> clips the last RETRO_SECONDS retroactively
# "aye clip this"  -> opens a forward clip; close with "aye clip that" or
#                     "aye end clip"; auto-closes at MAX_FORWARD_SECONDS
RETRO_PHRASES=aye clip that
START_PHRASES=aye clip this
END_PHRASES=aye end clip,aye stop clip
RETRO_SECONDS=60
MAX_FORWARD_SECONDS=90

# ============ Clip behavior ============
HOTKEY=ctrl+alt+c
TRIGGER_COOLDOWN_SECONDS=15
WATERMARK=@KhaosClipper
CAPTIONS=false
CLIP_TWEET_TEXT=LIVE right now — clipped in real time 🎬

# ============ AI Captions ============
# Claude transcribes your clip and suggests 3 SEO-optimized tweet captions.
# You get 10 seconds to pick one before it auto-posts with option 1.
AI_CAPTIONS=true
ANTHROPIC_API_KEY=
STREAMER_CONTEXT=crypto / Web3 streamer on X, live trade calls, Solana and Hyperliquid perps
CAPTION_PICK_TIMEOUT=10
# Caption style: yoxic_jack, crypto_alpha, comedy, narrative, default
# (see: khaosclip skills — or drop your own .json in skills/)
CAPTION_SKILL=default

# ============ Posting ============
AUTO_POST=true
DRY_RUN=false

# ============ Cloud Mode (NameiT relay — no X dev account needed) ============
# Connect once at the relay's /auth/login page, paste your key here.
CLOUD_MODE=false
NAMEIT_API_KEY=
RELAY_URL=

# ============ Growth loop ============
# Appended to every posted caption. Every clip becomes an ad for NameiT.
BRAND_TAG=🎬 clipped live by voice — nameit.vercel.app

# ============ Misc ============
LOG_LEVEL=INFO
VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
